# ============================================================
# OCI DB Metric Report - Configuration
# ============================================================
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
# ============================================================

# --- OCI CLI Configuration ---
# OCI config file path (default: ~/.oci/config)
OCI_CONFIG_FILE="~/.oci/config"

# OCI CLI profile name (default: DEFAULT)
OCI_PROFILE="DEFAULT"

# --- OCI Resource ---
# Compartment OCID (required)
COMPARTMENT_ID="ocid1.compartment.oc1..aaaaaaaaXXXXXXXXXXXX"

# --- Metric Collection ---
# Namespace: oci_postgresql or oci_mysql_database
NAMESPACE="oci_mysql_database"

# Collection interval (1m, 5m, 1h)
INTERVAL="1m"

# --- Time Range ---
# ISO 8601 UTC format: YYYY-MM-DDTHH:MM:SSZ
START_TIME="2026-03-12T06:00:00Z"
END_TIME="2026-03-12T07:00:00Z"

# --- Benchmark Window (optional, for chart highlight) ---
# Leave empty to skip highlight
BENCH_START="2026-03-12T06:29:00Z"
BENCH_END="2026-03-12T06:33:00Z"

# --- Output ---
# Output directory (auto-generated if empty)
OUTPUT_DIR=""

# Report title prefix
REPORT_TITLE="OCI MySQL Metric Report"
